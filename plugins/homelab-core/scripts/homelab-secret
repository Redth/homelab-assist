#!/usr/bin/env sh
# homelab-secret — store and retrieve homelab credentials in the OS-native secret store,
# so tokens/passwords never sit in plaintext dotfiles, the repo, or shell history.
#
# Backends (auto-detected): macOS Keychain (`security`), Linux libsecret (`secret-tool`)
# or `pass`. On Windows use homelab-secret.ps1 instead.
#
# Namespace: all secrets are stored under the service "homelab-assist"; the ACCOUNT you pick
# should match the environment variable its consumer expects (e.g. NPM_PASSWORD,
# PVE_TOKEN_SECRET, DOCKHAND_PASSWORD).
#
# Usage:
#   homelab-secret set   <KEY>                 # prompt (hidden) and store
#   homelab-secret set   <KEY> <VALUE>         # store VALUE (avoid: leaks to shell history)
#   homelab-secret get   <KEY>                 # print secret to stdout (for $(...) / piping)
#   homelab-secret run   <KEY[,KEY2,...]> -- <cmd...>   # export keys as env, exec cmd
#   homelab-secret has   <KEY>                 # exit 0 if present, 1 if not (prints nothing)
#   homelab-secret delete <KEY>                # remove
#   homelab-secret list                        # list stored keys (names only, never values)
#
# SECURITY: never echo a retrieved secret into logs or the chat. Prefer `run` (injects into
# the child's environment) or `get` piped directly into the consumer.
set -eu

SERVICE="homelab-assist"

_os() { uname -s 2>/dev/null || echo unknown; }

_backend() {
  case "$(_os)" in
    Darwin) echo keychain ;;
    Linux)
      if command -v secret-tool >/dev/null 2>&1; then echo secret-tool
      elif command -v pass >/dev/null 2>&1; then echo pass
      else echo none; fi ;;
    *) echo none ;;
  esac
}

_need_backend() {
  b=$(_backend)
  if [ "$b" = none ]; then
    echo "homelab-secret: no supported secret store found." >&2
    case "$(_os)" in
      Linux) echo "  Install libsecret tools ('secret-tool') or 'pass' (password-store)." >&2 ;;
      *) echo "  On Windows use homelab-secret.ps1." >&2 ;;
    esac
    exit 1
  fi
  echo "$b"
}

_set() { # KEY VALUE
  key=$1; val=$2
  case "$(_need_backend)" in
    keychain)   security add-generic-password -U -s "$SERVICE" -a "$key" -w "$val" >/dev/null ;;
    secret-tool) printf '%s' "$val" | secret-tool store --label="$SERVICE: $key" service "$SERVICE" account "$key" ;;
    pass)       printf '%s\n' "$val" | pass insert -m -f "$SERVICE/$key" >/dev/null ;;
  esac
}

_get() { # KEY -> stdout
  key=$1
  case "$(_need_backend)" in
    keychain)   security find-generic-password -s "$SERVICE" -a "$key" -w ;;
    secret-tool) secret-tool lookup service "$SERVICE" account "$key" ;;
    pass)       pass show "$SERVICE/$key" ;;
  esac
}

_has() { # KEY -> exit 0/1, no output
  key=$1
  case "$(_need_backend)" in
    keychain)   security find-generic-password -s "$SERVICE" -a "$key" -w >/dev/null 2>&1 ;;
    secret-tool) secret-tool lookup service "$SERVICE" account "$key" >/dev/null 2>&1 ;;
    pass)       pass show "$SERVICE/$key" >/dev/null 2>&1 ;;
  esac
}

_delete() { # KEY
  key=$1
  case "$(_need_backend)" in
    keychain)   security delete-generic-password -s "$SERVICE" -a "$key" >/dev/null 2>&1 || true ;;
    secret-tool) secret-tool clear service "$SERVICE" account "$key" 2>/dev/null || true ;;
    pass)       pass rm -f "$SERVICE/$key" >/dev/null 2>&1 || true ;;
  esac
}

cmd="${1:-}"
case "$cmd" in
  set)
    [ $# -ge 2 ] || { echo "usage: homelab-secret set <KEY> [VALUE]" >&2; exit 2; }
    key=$2
    if [ $# -ge 3 ]; then val=$3; else
      printf 'Value for %s (hidden): ' "$key" >&2
      stty -echo 2>/dev/null || true; IFS= read -r val; stty echo 2>/dev/null || true; echo >&2
    fi
    _set "$key" "$val"
    echo "stored $key in $SERVICE ($(_backend))." >&2 ;;
  get)
    [ $# -ge 2 ] || { echo "usage: homelab-secret get <KEY>" >&2; exit 2; }
    _get "$2" ;;
  has)
    [ $# -ge 2 ] || { echo "usage: homelab-secret has <KEY>" >&2; exit 2; }
    if _has "$2"; then exit 0; else exit 1; fi ;;
  delete|rm)
    [ $# -ge 2 ] || { echo "usage: homelab-secret delete <KEY>" >&2; exit 2; }
    _delete "$2"; echo "deleted $2." >&2 ;;
  run)
    # homelab-secret run KEY1,KEY2 -- cmd args...
    [ $# -ge 2 ] || { echo "usage: homelab-secret run <KEY[,KEY..]> -- <cmd...>" >&2; exit 2; }
    keys=$2; shift 2
    [ "${1:-}" = "--" ] && shift
    [ $# -ge 1 ] || { echo "homelab-secret run: missing command after --" >&2; exit 2; }
    oldIFS=$IFS; IFS=,
    for k in $keys; do
      v=$(_get "$k") || { echo "homelab-secret: '$k' not found (set it with: homelab-secret set $k)" >&2; exit 1; }
      export "$k=$v"
    done
    IFS=$oldIFS
    exec "$@" ;;
  list)
    # Names only — never values. Listing is best-effort and backend-dependent.
    case "$(_need_backend)" in
      keychain)    echo "Keychain has no clean per-service CLI list. Open Keychain Access.app and filter on '$SERVICE', or check a specific key with: homelab-secret has <KEY>." >&2 ;;
      pass)        pass ls "$SERVICE" 2>/dev/null || echo "(none under $SERVICE)" >&2 ;;
      secret-tool) echo "secret-tool has no list command. Track your key names in the homelab-secrets skill, or check one with: homelab-secret has <KEY>." >&2 ;;
    esac ;;
  ""|-h|--help|help)
    sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//' ;;
  *)
    echo "homelab-secret: unknown command '$cmd' (try: set get run has delete list)" >&2; exit 2 ;;
esac
