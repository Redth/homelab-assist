#!/usr/bin/env sh
# Thin launcher for the npm-mcp Native AOT MCP server.
#
# On first run it detects the client OS/arch, downloads the matching prebuilt binary from this
# repo's GitHub Releases (tag pinned in the sibling VERSION file), caches it, and execs it.
# No .NET runtime is required on the user's machine. Subsequent runs use the cached binary.
#
# Covers macOS and Linux clients (where Claude Code typically runs to drive a homelab). On
# Windows, use npm-mcp.cmd instead (and point .mcp.json at it).
set -eu

unset CDPATH
DIR=$(cd -- "$(dirname -- "$0")" && pwd)
REPO="Redth/homelab"
VERSION=$(cat "$DIR/VERSION")

os=$(uname -s)
arch=$(uname -m)
case "$os" in
  Darwin)
    case "$arch" in
      arm64) rid=osx-arm64 ;;
      x86_64) rid=osx-x64 ;;
      *) echo "npm-mcp: unsupported macOS arch '$arch'" >&2; exit 1 ;;
    esac ;;
  Linux)
    case "$arch" in
      aarch64|arm64) rid=linux-arm64 ;;
      x86_64) rid=linux-x64 ;;
      *) echo "npm-mcp: unsupported Linux arch '$arch'" >&2; exit 1 ;;
    esac ;;
  *)
    echo "npm-mcp: unsupported OS '$os' (on Windows use npm-mcp.cmd)" >&2; exit 1 ;;
esac

# Prefer the plugin's persistent data dir if Claude Code provides one; else cache beside the script.
CACHE="${CLAUDE_PLUGIN_DATA:-$DIR/.cache}"
BIN="$CACHE/npm-mcp-${VERSION}-${rid}"

if [ ! -x "$BIN" ]; then
  mkdir -p "$CACHE"
  url="https://github.com/${REPO}/releases/download/${VERSION}/npm-mcp-${rid}"
  echo "npm-mcp: downloading ${VERSION} (${rid})..." >&2
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$BIN.tmp"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$BIN.tmp" "$url"
  else
    echo "npm-mcp: need curl or wget to download the server binary" >&2; exit 1
  fi
  chmod +x "$BIN.tmp"
  mv "$BIN.tmp" "$BIN"
fi

# Resolve any missing NPM_* credentials from the OS secret store (homelab-core's homelab-secret
# helper, if on PATH) so they never have to live in a dotfile. Existing env values win.
if command -v homelab-secret >/dev/null 2>&1; then
  for k in NPM_URL NPM_EMAIL NPM_PASSWORD NPM_VERIFY_SSL; do
    eval "cur=\${$k:-}"
    if [ -z "$cur" ] && homelab-secret has "$k" 2>/dev/null; then
      eval "export $k=\"\$(homelab-secret get \"$k\")\""
    fi
  done
fi

exec "$BIN" "$@"
